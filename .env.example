# InsForge SDK (server-only — this app does NOT use DATABASE_URL)
# The API route talks to InsForge via REST using these two vars.
# Get values from: npx @insforge/cli current --json
INSFORGE_URL=https://kbh3w9yv.us-east.insforge.app
INSFORGE_API_KEY=ik_your_api_key_here

# DATABASE_URL (optional, NOT used by this app)
# InsForge dashboard may show a Postgres connection string for direct DB
# access (psql, Prisma, etc.). Migrations use the CLI instead:
#   npx @insforge/cli db migrations up --all
# Only add DATABASE_URL if you wire up a direct Postgres client yourself.

# Optional: client-side SDK (when you add auth or direct reads)
VITE_INSFORGE_URL=https://kbh3w9yv.us-east.insforge.app
VITE_INSFORGE_ANON_KEY=your_anon_key_from_insforge_cli_secrets_get_ANON_KEY
